* {
    bg0:        rgba(22, 22, 22, 100%);
    bg1:        rgba(22, 22, 22, 100%);
    bg2:        rgba(50, 50, 52, 100%);
    bg3:        rgba(60, 60, 65, 100%);

    fg0:        rgba(242, 242, 247, 100%);
    fg1:        rgba(174, 174, 178, 100%);
    fg2:        rgba(99,  99,  102, 100%);

    accent:     rgba(137, 91, 244, 100%);
