* {
    bg0:        rgba(22,  22,  22,  100%);
    bg1:        rgba(30,  30,  30,  100%);
    bg2:        rgba(67,  74,  76,  100%);

    fg0:        rgba(198, 198, 198, 100%);
    fg1:        rgba(198, 198, 198, 100%);
    fg2:        rgba(85,  85,  85,  100%);

    accent:     rgba(137, 91,  244, 100%);
    accent-dim: rgba(137, 91,  244, 25%);

    border-col: rgba(255, 255, 255, 7%);
}
